# Nodi Environment Configuration
# ============================

# The port the application will listen on inside the container
QL_PORT=8080

# The root directory for file storage (mapped to /data in Docker)
QL_ROOT=/data

# Admin Username
QL_USER=admin

# Admin Password Hash (BCrypt)
# Use a tool like 'htpasswd -B' or a Go script to generate this.
# Example for 'admin': $2y$10$y58t9Y6PqBf9N6qA58t9Ye8... (Placeholder)
QL_PASS_HASH=$2y$10$y58t9Y6PqBf9N6qA58t9Ye8Zp6iS6Y7YmS6i6Y7YmS6i6Y7YmS6i6

# Cookie Secret (At least 32 characters for security)
QL_COOKIE_SECRET=change-this-to-something-very-secure-and-long-please

# Default Theme (light, dark, system)
QL_THEME=system

# Max Upload Size in bytes (Default: 2GB)
# QL_MAX_UPLOAD=2147483648
