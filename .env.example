# Nodi Environment Configuration
# ==============================
# Copy this file to .env for local development or nodi.env for Docker.
# These defaults are intentionally large-file-friendly: uploads stream to disk,
# chunk state lives under QL_ROOT, and Go temp files should not use tmpfs.

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------

# Port the HTTP server listens on. Must be a number between 1024 and 65535.
# Default: 7319
QL_PORT=7319

# Root directory for file storage. Must exist and be writable by the server.
# In Docker this is mapped to /nodi_files. In local dev use an absolute or
# relative path. Keep this on real disk, not tmpfs, for 20GB-100GB uploads.
# Default: ./nodi_files
QL_ROOT=./nodi_files

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------

# Admin username. Single-user only for now.
# Default: admin
QL_USER=admin

# Admin password hash (BCrypt). Generate with:
#   htpasswd -nbBC 10 admin "your-password" | cut -d: -f2
# Must start with $2a$, $2b$, or $2y$.
# Example below is the bcrypt hash for password: "admin".
# Change this before exposing Nodi beyond a throwaway local test.
QL_PASS_HASH=$2b$10$giD/vH5ZWt26q8GEN0PdZejq/ZdpxdMci5bK4U2fnLHj1mfqZXmCy

# Alternative for first boot only: omit QL_PASS_HASH and provide a generated
# bootstrap password. Nodi hashes it in memory at boot. Prefer QL_PASS_HASH for
# long-lived config files, and change the password from Settings after login.
# QL_BOOTSTRAP_PASSWORD=

# Secret key for signing session cookies. MUST be at least 32 bytes.
# Generate a secure random value with:
#   openssl rand -base64 48
# If this leaks, all sessions are compromised. Rotate to invalidate sessions.
QL_COOKIE_SECRET=change-this-to-a-random-string-at-least-32-bytes-long

# Session expiry duration. Valid Go duration strings: "24h", "7d", "168h", etc.
# The session is refreshed (sliding expiration) on every API request, so active
# users stay logged in. This value controls the idle timeout.
# Default: 24h
# QL_SESSION_EXPIRY=24h

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------

# Comma-separated list of trusted reverse proxy IPs or CIDR ranges.
# When set, the rate limiter and logging use X-Forwarded-For instead of RemoteAddr.
# Example: "10.0.0.0/8,192.168.1.1"
# Default: (empty — disabled)
# QL_TRUSTED_PROXY=

# ------------------------------------------------------------------------------
# Uploads
# ------------------------------------------------------------------------------

# Maximum upload size in bytes. The default is 1 TiB so large LAN uploads work
# without editing config. Set a smaller value only if you deliberately want a cap.
# Default: 1099511627776 (1 TiB)
QL_MAX_UPLOAD=1099511627776

# Maximum size of one resumable-upload chunk in bytes.
# Default: 16777216 (16 MiB)
QL_MAX_CHUNK_SIZE=16777216

# How long abandoned resumable upload sessions are kept before cleanup.
# Valid Go duration strings: "48h", "72h", "168h".
# Default: 48h
QL_UPLOAD_TTL=48h

# Where Go writes temporary files. In Docker this should live on the storage
# volume, not /tmp tmpfs. For local development it may be omitted, but keeping it
# under QL_ROOT makes large restore/backup operations safer.
# Docker default: /nodi_files/.cache/tmp
# GOTMPDIR=/nodi_files/.cache/tmp

# How long deleted files remain in trash before automatic cleanup.
# Default: 720h (30 days)
QL_TRASH_RETENTION=720h

# ------------------------------------------------------------------------------
# Appearance
# ------------------------------------------------------------------------------

# Default theme for new visitors. Options: "light", "dark", "system"
# Users can override in the UI. Stored in localStorage.
# Default: system
QL_THEME=system
